  {
    "id": "TC001",
    "title": "Replace an invalid (too large) image with a valid image and save successfully",
    "description": "Verifies the admin can correct a file size error by replacing the image and then saving successfully.",
    "category": "Landing Page Management (LPM)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/admin\""
      },
      {
        "type": "action",
        "description": "Click on the \"LPM\" option in the admin navigation/menu"
      },
      {
        "type": "action",
        "description": "Click the \"Add Course\" button"
      },
      {
        "type": "assertion",
        "description": "Verify the \"Save\" button is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"5MB\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Cancel\" or close button to exit the Add Course form without saving"
      }
    ]
  },
